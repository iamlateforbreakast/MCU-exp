# Dockerfile to build a container image to use Rust on top of RTEMS
FROM ubuntu:24.04

LABEL com.github.containers.toolbox="true" \
      com.github.debarshiray.toolbox="true"

RUN apt-get update && \
    apt-get -y upgrade && \
    apt-get install -y \
        bison \
        build-essential \
        curl \
        flex \
        g++ \
        gdb \
        git \
        libncurses5-dev \
        ninja-build \
        pax \
        pkg-config \
        python3-dev \
        python-is-python3 \
        qemu-system-misc \
        texinfo \
        unzip \
        libcap2-bin \
        sudo \
        zlib1g-dev && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*
RUN useradd -c "Rust Developer" -g "users" \
            -d "/home/thomas" --create-home "thomas" && \
    mkdir -p /opt/rtems && \
    chown thomas:users /opt/rtems && \
    runuser -u thomas echo \
            'export PATH=/opt/rtems/7/bin:${PATH}' \
            >>/home/thomas/.bashrc

RUN sed -i -e 's/ ALL$/ NOPASSWD:ALL/' /etc/sudoers
RUN touch /etc/localtime
RUN echo VARIANT_ID=container >> /etc/os-release

USER thomas
WORKDIR /home/thomas
CMD ["/bin/bash"]
